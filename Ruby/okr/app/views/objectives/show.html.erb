<div class="max-w-3xl mx-auto px-4 py-8">

  <%# Back link %>
  <%= link_to "← Back to Objectives", objectives_path,
        class: "text-sm text-gray-400 hover:text-indigo-600 font-medium transition-colors duration-200 mb-6 inline-block" %>

  <%# Objective Card %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">

    <%# Header: Title + Actions %>
    <div class="flex items-start justify-between gap-4 mb-6">
      <h1 class="text-2xl font-bold text-gray-900"><%= @objective.title %></h1>
      <div class="flex items-center gap-2 shrink-0">
        <%= link_to "Edit", edit_objective_path(@objective),
              class: "text-sm font-semibold px-4 py-2 rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-600 transition-colors duration-200" %>
        <%= button_to "Delete", @objective, method: :delete,
              class: "text-sm font-semibold px-4 py-2 rounded-lg bg-red-50 hover:bg-red-100 text-red-600 transition-colors duration-200 cursor-pointer border-0",
              data: { turbo_confirm: "Are you sure you want to delete this objective?" } %>
      </div>
    </div>

    <%# Key Results Section %>
    <div class="mb-2">
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Key Results</h2>

      <% if @objective.key_results.any? %>
        <ul class="flex flex-col gap-2">
          <% @objective.key_results.each do |kr| %>
            <li class="flex items-center justify-between bg-indigo-50 border border-indigo-100 rounded-xl px-4 py-3 gap-4">
              <div class="flex flex-col gap-0.5">
                <span class="text-sm font-medium text-gray-800"><%= kr.description %></span>
                <span class="text-xs text-gray-400">Target: <%= kr.target_value %><%= kr.metric %></span>
              </div>
              <%= button_to "Delete", [@objective, kr], method: :delete,
                    class: "text-xs font-semibold px-3 py-1.5 rounded-lg bg-red-50 hover:bg-red-100 text-red-500 transition-colors duration-200 cursor-pointer border-0 shrink-0",
                    data: { turbo_confirm: "Delete this key result?" } %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm italic text-gray-400 py-2">No key results yet. Add one below!</p>
      <% end %>
    </div>

  </div>

  <%# Add Key Result Card %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Add Key Result</h3>

    <%= form_with(model: [@objective, KeyResult.new], local: true) do |form| %>

      <div class="mb-4">
        <%= form.label :description, class: "block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1" %>
        <%= form.text_field :description,
              placeholder: "e.g. Increase revenue by 20%",
              class: "w-full px-3 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition" %>
      </div>

      <div class="flex gap-4 mb-5">
        <div class="flex-1">
          <%= form.label :target_value, class: "block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1" %>
          <%= form.number_field :target_value, value: 100,
                class: "w-full px-3 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition" %>
        </div>
        <div class="flex-1">
          <%= form.label :metric, class: "block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1" %>
          <%= form.text_field :metric, value: "%",
                class: "w-full px-3 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition" %>
        </div>
      </div>

      <%= form.submit "Add Key Result",
            class: "bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors duration-200 cursor-pointer border-0" %>

    <% end %>
  </div>

</div>
