<div class="max-w-3xl mx-auto px-4 py-8">

  <%= link_to "← Back to Objective", @objective,
        class: "text-sm text-gray-400 hover:text-indigo-600 font-medium transition-colors duration-200 mb-6 inline-block" %>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
    <h1 class="text-2xl font-bold text-gray-900 mb-1">Edit Objective</h1>
    <p class="text-sm text-gray-400 mb-6">Update what you want to achieve.</p>

    <hr class="border-gray-100 mb-6">

    <%= render "form", objective: @objective %>

    <%= link_to "Cancel", @objective,
          class: "text-sm font-semibold px-4 py-2 rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-600 transition-colors duration-200 inline-block mt-3" %>
  </div>

</div>
